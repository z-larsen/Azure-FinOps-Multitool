<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Azure FinOps Scanner"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="AzureBlue" Color="#0078D4"/>
        <SolidColorBrush x:Key="AzureDark" Color="#004578"/>
        <SolidColorBrush x:Key="AzureLight" Color="#DEECF9"/>
        <SolidColorBrush x:Key="CardBg" Color="White"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#333333"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#666666"/>

        <DropShadowEffect x:Key="CardShadow" ShadowDepth="1" BlurRadius="6" Opacity="0.12" Direction="270"/>

        <!-- Button Style -->
        <Style x:Key="AzureButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section Header Style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>

        <!-- Card Border Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
        </Style>

        <!-- DataGrid Style -->
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#005A9E"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Header Bar ============================================== -->
        <Border DockPanel.Dock="Top" Background="#0078D4" Padding="16,10">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#9729;" FontSize="24" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Azure FinOps Scanner" FontSize="20" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TenantLabel" Text="" FontSize="12" Foreground="#B3D7F2" VerticalAlignment="Center" Margin="16,3,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button x:Name="ScanButton" Content="&#x26A1; Scan Tenant" Style="{StaticResource AzureButton}"
                            Background="White" Foreground="#0078D4" Margin="0,0,8,0"/>
                    <Button x:Name="ExportButton" Content="&#x1F4CB; Export Report" Style="{StaticResource AzureButton}"
                            Background="Transparent" Foreground="White" BorderBrush="White" IsEnabled="False"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status Bar ============================================== -->
        <Border DockPanel.Dock="Bottom" Background="#F8F8F8" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel>
                <ProgressBar x:Name="ProgressBar" Width="220" Height="14" Minimum="0" Maximum="100" Value="0"
                             Foreground="#0078D4" Background="#E0E0E0" DockPanel.Dock="Right" Margin="10,0,0,0"/>
                <TextBlock x:Name="StatusText" Text="Click 'Scan Tenant' to begin" Foreground="#666"
                           FontSize="12" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Main Content ============================================ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Hierarchy Tree -->
            <DockPanel Grid.Column="0" Background="White">
                <Border DockPanel.Dock="Top" Background="#F8F8F8" Padding="12,10" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <TextBlock Text="Management Group Hierarchy" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                </Border>
                <TreeView x:Name="HierarchyTree" BorderThickness="0" Padding="4" FontSize="12.5"/>
            </DockPanel>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Background="#E0E0E0" ResizeBehavior="PreviousAndNext"/>

            <!-- Right Panel: Detail Tabs -->
            <TabControl x:Name="DetailTabs" Grid.Column="2" Padding="0" BorderThickness="0" Background="#F0F0F0">

                <!-- Overview Tab ================================== -->
                <TabItem Header="  Overview  " FontSize="13">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                        <StackPanel x:Name="OverviewPanel">

                            <!-- Summary Cards Row -->
                            <WrapPanel Margin="0,10,0,10">
                                <Border Style="{StaticResource Card}" Width="210">
                                    <StackPanel>
                                        <TextBlock Text="Contract Type" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="ContractTypeText" Text="&#x2014;" FontSize="18" FontWeight="Bold" Foreground="#0078D4" Margin="0,4,0,0"/>
                                        <TextBlock x:Name="ContractDetailText" Text="" FontSize="11" Foreground="#999" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="210">
                                    <StackPanel>
                                        <TextBlock Text="Month-to-Date Spend" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="TotalCostText" Text="&#x2014;" FontSize="24" FontWeight="Bold" Foreground="#D83B01" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="210">
                                    <StackPanel>
                                        <TextBlock Text="Forecasted Spend" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="ForecastText" Text="&#x2014;" FontSize="24" FontWeight="Bold" Foreground="#8764B8" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="210">
                                    <StackPanel>
                                        <TextBlock Text="Subscriptions" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="SubCountText" Text="&#x2014;" FontSize="24" FontWeight="Bold" Foreground="#0078D4" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="210">
                                    <StackPanel>
                                        <TextBlock Text="Est. Annual Savings" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="TotalSavingsText" Text="&#x2014;" FontSize="24" FontWeight="Bold" Foreground="#107C10" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <!-- Subscription Cost Table -->
                            <TextBlock Text="Subscription Costs" Style="{StaticResource SectionHeader}"/>
                            <DataGrid x:Name="SubCostGrid" MaxHeight="250"/>

                            <!-- Resource Cost Table -->
                            <TextBlock Text="Resources by Spend" Style="{StaticResource SectionHeader}"/>
                            <TextBlock x:Name="ResourceCountNote" FontSize="11" Foreground="#999" Margin="0,0,0,6"/>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <DataGrid x:Name="ResourceCostGrid" MaxHeight="500" MinWidth="900"/>
                            </ScrollViewer>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Cost Analysis Tab ============================= -->
                <TabItem Header="  Cost Analysis  " FontSize="13">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                        <StackPanel x:Name="CostPanel">
                            <TextBlock x:Name="CostByTagHeader" Text="Cost by Tag" Style="{StaticResource SectionHeader}"/>
                            <TextBlock x:Name="CostByTagDesc" Text="Select a tag below to see cost distribution." FontSize="12" Foreground="#666" Margin="0,0,0,10"/>
                            <ComboBox x:Name="TagSelector" Width="250" HorizontalAlignment="Left" Margin="0,0,0,15" FontSize="12" Padding="6,4"/>
                            <DataGrid x:Name="CostByTagGrid" MaxHeight="400"/>

                            <TextBlock x:Name="NoTagsLabel" Text="" FontSize="13" Foreground="#D83B01" Margin="0,20,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tags Tab ====================================== -->
                <TabItem Header="  Tags  " FontSize="13">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                        <StackPanel x:Name="TagsPanel">

                            <!-- Tag Coverage Summary -->
                            <WrapPanel Margin="0,10,0,10">
                                <Border Style="{StaticResource Card}" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="Unique Tags" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="TagCountText" Text="&#x2014;" FontSize="22" FontWeight="Bold" Foreground="#0078D4"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="Tag Coverage" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="TagCoverageText" Text="&#x2014;" FontSize="22" FontWeight="Bold" Foreground="#107C10"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="180">
                                    <StackPanel>
                                        <TextBlock Text="Untagged Resources" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="UntaggedCountText" Text="&#x2014;" FontSize="22" FontWeight="Bold" Foreground="#D83B01"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <!-- Tag Inventory -->
                            <TextBlock Text="Tag Inventory" Style="{StaticResource SectionHeader}"/>
                            <DataGrid x:Name="TagInventoryGrid" MaxHeight="250"/>

                            <!-- Tag Recommendations -->
                            <TextBlock Text="Tag Recommendations (Cloud Adoption Framework)" Style="{StaticResource SectionHeader}"/>
                            <TextBlock x:Name="TagComplianceText" Text="" FontSize="13" Margin="0,0,0,8"/>
                            <DataGrid x:Name="TagRecsGrid" MaxHeight="300"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Optimization Tab ============================== -->
                <TabItem Header="  Optimization  " FontSize="13">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                        <StackPanel x:Name="OptPanel">

                            <!-- Savings Summary Cards -->
                            <WrapPanel Margin="0,10,0,10">
                                <Border Style="{StaticResource Card}" Width="220">
                                    <StackPanel>
                                        <TextBlock Text="AHB Opportunities" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="AHBCountText" Text="&#x2014;" FontSize="22" FontWeight="Bold" Foreground="#D83B01"/>
                                        <TextBlock x:Name="AHBDetailText" Text="" FontSize="11" Foreground="#999"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="220">
                                    <StackPanel>
                                        <TextBlock Text="Reserved Instances" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="RICountText" Text="&#x2014;" FontSize="22" FontWeight="Bold" Foreground="#8764B8"/>
                                        <TextBlock x:Name="RISavingsText" Text="" FontSize="11" Foreground="#999"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="220">
                                    <StackPanel>
                                        <TextBlock Text="Savings Plans" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="SPCountText" Text="&#x2014;" FontSize="22" FontWeight="Bold" Foreground="#0078D4"/>
                                        <TextBlock x:Name="SPSavingsText" Text="" FontSize="11" Foreground="#999"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Width="220">
                                    <StackPanel>
                                        <TextBlock Text="Advisor Optimizations" FontSize="11" Foreground="#999"/>
                                        <TextBlock x:Name="AdvisorCountText" Text="&#x2014;" FontSize="22" FontWeight="Bold" Foreground="#0078D4"/>
                                        <TextBlock x:Name="AdvisorSavingsText" Text="" FontSize="11" Foreground="#999"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>

                            <!-- AHB Section -->
                            <TextBlock Text="Azure Hybrid Benefit &#x2014; Eligible Resources" Style="{StaticResource SectionHeader}"/>
                            <TextBlock Text="Use existing Windows Server or SQL Server licenses with Software Assurance to save 40-85% on Azure VMs and SQL services. No additional purchase needed if you already own on-prem licenses." FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBlock x:Name="AHBSummaryText" Text="" FontSize="12" Foreground="#666" Margin="0,0,0,8"/>
                            <DataGrid x:Name="AHBGrid" MaxHeight="200"/>

                            <!-- RI Section -->
                            <TextBlock Text="Reserved Instance Recommendations" Style="{StaticResource SectionHeader}" Margin="0,20,0,0"/>
                            <TextBlock Text="Reserved Instances (RIs) lock in a discounted rate for a specific resource type (VM size, SQL tier, etc.) in a specific region for 1 or 3 years. Best for steady-state workloads with predictable usage. Typical savings: 30-72% vs. pay-as-you-go." FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            <TextBlock x:Name="RIContractNote" Text="" FontSize="11" Foreground="#8764B8" Margin="0,0,0,8"/>
                            <DataGrid x:Name="RIGrid" MaxHeight="300"/>

                            <!-- Savings Plan Section -->
                            <TextBlock Text="Savings Plan Recommendations" Style="{StaticResource SectionHeader}" Margin="0,20,0,0"/>
                            <TextBlock Text="Savings Plans commit to a fixed hourly spend across any VM family, region, or OS for 1 or 3 years. More flexible than RIs since they auto-apply to whatever compute you run. Best for dynamic workloads that change VM sizes or regions over time. Typical savings: 15-65% vs. pay-as-you-go." FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,0,0,4"/>
                            <TextBlock x:Name="SPContractNote" Text="" FontSize="11" Foreground="#0078D4" Margin="0,0,0,8"/>
                            <DataGrid x:Name="SPGrid" MaxHeight="300"/>

                            <!-- Advisor Section -->
                            <TextBlock Text="Advisor Cost Recommendations" Style="{StaticResource SectionHeader}" Margin="0,20,0,0"/>
                            <TextBlock Text="Azure Advisor analyzes your resource usage patterns and identifies wasteful spend: idle VMs, oversized resources, orphaned disks, and underutilized services. These are quick wins that reduce cost without any commitment." FontSize="11" Foreground="#999" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <DataGrid x:Name="AdvisorGrid" MaxHeight="250"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- FinOps Guidance Tab =========================== -->
                <TabItem Header="  FinOps Guidance  " FontSize="13">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
                        <StackPanel x:Name="GuidancePanel">
                            <TextBlock Text="FinOps Maturity Assessment" Style="{StaticResource SectionHeader}"/>
                            <TextBlock x:Name="GuidanceText" TextWrapping="Wrap" FontSize="13" Foreground="#333"
                                       Text="Scan results will generate FinOps guidance here based on the three pillars: Understand, Quantify, and Optimize."/>

                            <TextBlock Text="Understand (Cost Visibility &amp; Allocation)" Style="{StaticResource SectionHeader}" Foreground="#0078D4"/>
                            <TextBlock x:Name="UnderstandText" TextWrapping="Wrap" FontSize="12.5" Foreground="#444" Margin="0,0,0,10"/>

                            <TextBlock Text="Quantify (Budgeting &amp; Forecasting)" Style="{StaticResource SectionHeader}" Foreground="#8764B8"/>
                            <TextBlock x:Name="QuantifyText" TextWrapping="Wrap" FontSize="12.5" Foreground="#444" Margin="0,0,0,10"/>

                            <TextBlock Text="Optimize (Rate &amp; Usage Optimization)" Style="{StaticResource SectionHeader}" Foreground="#107C10"/>
                            <TextBlock x:Name="OptimizeText" TextWrapping="Wrap" FontSize="12.5" Foreground="#444" Margin="0,0,0,10"/>

                            <TextBlock Text="References" Style="{StaticResource SectionHeader}"/>
                            <TextBox x:Name="ReferencesText" TextWrapping="Wrap" FontSize="12" Foreground="#0078D4" Margin="0,0,0,10"
                                     IsReadOnly="True" BorderThickness="0" Background="Transparent" Cursor="IBeam"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
